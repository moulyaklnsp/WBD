# --- Database ---
MONGODB_URI=mongodb://localhost:27017/chesshive

# --- Session ---
SESSION_SECRET=your_session_secret_here
SESSION_COOKIE_NAME=sid

# --- JWT Secrets (CHANGE THESE IN PRODUCTION!) ---
JWT_ACCESS_SECRET=chesshive_access_jwt_secret_change_this_in_production
JWT_REFRESH_SECRET=chesshive_refresh_jwt_secret_change_this_in_production

# --- Server ---
PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated allowed origins). When unset, the backend allows any origin.
CLIENT_ORIGIN=http://localhost:3000

# Set to 1 when running behind a reverse proxy (Railway, Render, etc).
TRUST_PROXY=0

# --- Redis / Cache ---
# Set CACHE_ENABLED=false if you want to run without Redis.
REDIS_URL=redis://127.0.0.1:6379
CACHE_ENABLED=true
CACHE_PREFIX=chesshive
CACHE_DEFAULT_TTL_SECONDS=120
CACHE_LONG_TTL_SECONDS=900
CACHE_COMMAND_TIMEOUT_MS=150
CACHE_LOGS=true
REDIS_CONNECT_TIMEOUT_MS=1000

# --- Email (SendGrid) ---
# Verified sender email recommended for production.
SENDGRID_API_KEY=your_sendgrid_api_key_here
SMTP_FROM=noreply@chesshive.com

