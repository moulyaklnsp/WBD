# Used by the production build (Vercel) to target your deployed backend.
# Leave empty in local dev (CRA proxy handles /api/*).
REACT_APP_API_URL=https://your-backend.up.railway.app

# Optional: override Socket.IO URL (defaults to REACT_APP_API_URL when set).
REACT_APP_SOCKET_URL=https://your-backend.up.railway.app

